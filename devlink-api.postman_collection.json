    "item": [
        {
            "name": "Auth",
            "description": "Authentication endpoints (register, login, logout)",
            "item": [
                {
                    "name": "Register",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.collectionVariables.set('token', jsonData.data.token);",
                                    "    pm.test('User registered successfully', function () {",
                                    "        pm.expect(jsonData.message).to.eql('User registered successfully');",
                                    "        pm.expect(jsonData.data.user).to.have.property('id');",
                                    "        pm.expect(jsonData.data.user).to.have.property('name');",
                                    "        pm.expect(jsonData.data.user).to.have.property('email');",
                                    "        pm.expect(jsonData.data).to.have.property('token');",
                                    "    });",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/auth/register",
                            "host": ["{{base_url}}"],
                            "path": ["api", "v1", "auth", "register"]
                        },
                        "description": "Register a new user account. Returns user data and bearer token."
                    },
                    "response": [
                        {
                            "name": "Success (201)",
                            "status": "Created",
                            "code": 201,
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n    \"message\": \"User registered successfully\",\n    \"data\": {\n        \"user\": {\n            \"id\": 1,\n            \"name\": \"John Doe\",\n            \"email\": \"john@example.com\"\n        },\n        \"token\": \"1|abc123token...\"\n    }\n}"
                        },
                        {
                            "name": "Validation Error (422)",
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n    \"message\": \"The email has already been taken.\",\n    \"errors\": {\n        \"email\": [\n            \"The email has already been taken.\"\n        ]\n    }\n}"
                        }
                    ]
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.collectionVariables.set('token', jsonData.data.token);",
                                    "    pm.test('Login successful', function () {",
                                    "        pm.expect(jsonData.message).to.eql('Login successful');",
                                    "        pm.expect(jsonData.data.user).to.have.property('id');",
                                    "        pm.expect(jsonData.data).to.have.property('token');",
                                    "    });",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/auth/login",
                            "host": ["{{base_url}}"],
                            "path": ["api", "v1", "auth", "login"]
                        },
                        "description": "Login with email and password. Returns user data and bearer token.\n\nThe token is automatically saved to collection variables."
                    },
